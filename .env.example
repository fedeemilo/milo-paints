# =====================================================
# MONGODB
# Connection string del cluster (Atlas). Usar un usuario
# con acceso solo a la DB milo-paints (readWrite).
# =====================================================
MONGODB_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/?appName=milo-paints
MONGODB_DB_NAME=milo-paints

# =====================================================
# CLOUDINARY
# Obtener de: https://console.cloudinary.com/settings/api-keys
# =====================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# =====================================================
# AUTENTICACIÓN ADMIN
# Elegí una contraseña segura para acceder al panel admin.
# SESSION_SECRET firma la cookie (HMAC). Si no está, se usa
# ADMIN_PASSWORD como fallback — en prod conviene setear ambos.
# =====================================================
ADMIN_PASSWORD=tu-contraseña-segura-aqui
SESSION_SECRET=genera-un-string-largo-y-aleatorio

# =====================================================
# CONFIGURACIÓN DE LA APP
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
